{
	"name": "@codex-session-auto-rename/remotion",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"studio": "remotion studio src/index.tsx --port=3001",
		"compositions": "remotion compositions src/index.tsx",
		"render": "npm run render:video",
		"render:video": "remotion render src/index.tsx CodexSessionAutoRename out/codex-session-auto-rename.mp4 --codec=h264 --crf=18",
		"render:still": "remotion still src/index.tsx CodexSessionAutoRenamePoster out/poster.png",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@remotion/cli": "4.0.477",
		"react": "19.2.3",
		"react-dom": "19.2.3",
		"remotion": "4.0.477"
	},
	"devDependencies": {
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3",
		"typescript": "6.0.3"
	}
}
