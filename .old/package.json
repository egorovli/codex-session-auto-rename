{
	"name": "codex-session-auto-rename",
	"version": "0.1.0",
	"description": "Bun/TypeScript Codex hook for conservative automatic thread title updates.",
	"type": "module",
	"private": true,
	"bin": {
		"codex-session-auto-rename": "./src/auto-rename.ts"
	},
	"scripts": {
		"capture": "bun src/auto-rename.ts capture",
		"decide": "bun src/auto-rename.ts decide",
		"suggest": "bun src/auto-rename.ts suggest",
		"install:global": "bun src/install.ts",
		"test": "bun test",
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check --write ."
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.0",
		"@types/bun": "^1.3.2",
		"typescript": "6.0.3"
	}
}
